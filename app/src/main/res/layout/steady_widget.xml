<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E2937"
    android:padding="8dp">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Steady"
        android:textColor="#22C55E"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <!-- Scrollable full-day habit list -->
    <ListView
        android:id="@+id/widget_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent" />

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All done for today ✓"
        android:textColor="#22C55E"
        android:textSize="13sp"
        android:padding="12dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Footer: Capture / Log (like Today) + Open Steady — colors set at render from app theme -->
    <LinearLayout
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/capture_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="+ Capture"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="#22C55E"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/log_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="+ Log"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="#22C55E"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/open_btn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Open Steady"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="#22C55E"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
