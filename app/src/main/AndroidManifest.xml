<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- LAN local web UI (#38) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Read current SSID for trusted-Wi‑Fi auto web server (GrapheneOS: grant Nearby devices / location) -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="33" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Exact alarms for reminders (Android 12+; user must grant in Settings) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Auto-log sensors (all opt-in via OS settings / runtime prompts) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-feature android:name="android.hardware.sensor.light" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Steady"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Steady"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Boot receiver: reschedule reminders after reboot -->
        <receiver
            android:name=".reminders.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Reminder alarm receiver -->
        <receiver
            android:name=".reminders.ReminderReceiver"
            android:enabled="true"
            android:exported="true" />

        <!-- Widget toggle action receiver (not exported: only our PendingIntents target it) -->
        <receiver
            android:name=".widget.ToggleReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.steady.habittracker.widget.ACTION_TOGGLE" />
                <action android:name="com.steady.habittracker.widget.ACTION_OPEN_LOG" />
                <action android:name="com.steady.habittracker.widget.ACTION_OPEN_CAPTURE" />
                <action android:name="com.steady.habittracker.widget.ACTION_OPEN_METRIC_LOG" />
                <action android:name="com.steady.habittracker.widget.ACTION_OPEN_APP" />
            </intent-filter>
        </receiver>

        <!-- Home screen widget provider -->
        <receiver
            android:name=".widget.SteadyWidgetProvider"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/steady_widget_info" />
        </receiver>

        <!-- Scrollable widget list (full-day habits) -->
        <service
            android:name=".widget.WidgetListService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Gadgetbridge / Tasker / adb external metrics (steps, etc.) -->
        <receiver
            android:name=".sensors.ExternalMetricsReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.steady.habittracker.ACTION_EXTERNAL_METRIC" />
                <action android:name="com.steady.habittracker.ACTION_EXTERNAL_STEPS" />
            </intent-filter>
        </receiver>

        <!-- Overnight OGG sleep / snore capture -->
        <service
            android:name=".sleepaudio.SleepAudioService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <receiver
            android:name=".sleepaudio.SleepAudioAlarmReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.steady.habittracker.sleepaudio.ALARM_START" />
                <action android:name="com.steady.habittracker.sleepaudio.ALARM_STOP" />
            </intent-filter>
        </receiver>

        <!-- LAN web UI server (keeps sockets alive while enabled) -->
        <service
            android:name=".web.LocalWebService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
